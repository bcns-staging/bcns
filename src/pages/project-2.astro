---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import BeaconsDirectory from "../components/islands/BeaconsDirectory.tsx";
---

<style>
  section {
    padding-block: 2rem 3rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 0.5rem;
  }

  .intro {
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 0 1.5rem;
  }

  :global(.beacons-directory) {
    max-width: 60rem;
  }

  :global(.beacons-filters) {
    display: flex;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  :global(.beacons-filters button) {
    padding: 0.4rem 0.9rem;
    border: 1px solid var(--color-border, #ccc);
    border-radius: 999px;
    background: transparent;
    cursor: pointer;
    font: inherit;
  }

  :global(.beacons-filters button.active) {
    background: var(--color-accent, #222);
    color: var(--color-bg, #fff);
    border-color: var(--color-accent, #222);
  }

  :global(.beacons-error) {
    color: #b3261e;
  }

  :global(.beacons-list) {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 1rem;
    grid-template-columns: repeat(auto-fill, minmax(16rem, 1fr));
  }

  :global(.beacons-list li) {
    border: 1px solid var(--color-border, #ddd);
    border-radius: 0.75rem;
    padding: 1rem;
  }

  :global(.beacons-list h3) {
    margin: 0 0 0.4rem;
    font-size: 1.1rem;
  }

  :global(.beacons-list p) {
    margin: 0 0 0.6rem;
    color: var(--color-text-muted);
  }

  :global(.beacon-status) {
    display: inline-block;
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    padding: 0.15rem 0.5rem;
    border-radius: 999px;
  }

  :global(.status-active) {
    background: #dff5e1;
    color: #1e6b2e;
  }

  :global(.status-planned) {
    background: #fff3cd;
    color: #8a6300;
  }

  :global(.status-archived) {
    background: #eee;
    color: #666;
  }
</style>

<Layout title="Project 2 | 7 Beacons">
  <Header />
  <main>
    <section>
      <h1>Project 2: GraphQL demo</h1>
      <p class="intro">
        A small GraphQL API, deployed as its own Cloud Run service, queried
        live from this page.
      </p>
      <BeaconsDirectory client:load />
    </section>
  </main>
  <Footer />
</Layout>
