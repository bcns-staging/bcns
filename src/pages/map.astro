---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GlobeMap from "../components/map/GlobeMap.tsx";
---

<style>
  section {
    padding-block: 2rem 3rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 0.5rem;
  }

  .intro {
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 0 1.5rem;
  }

  :global(.globe-wrap) {
    position: relative;
    width: 100%;
    height: min(70vh, 40rem);
    min-height: 20rem;
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  :global(.globe-wrap:fullscreen) {
    height: 100vh;
    border-radius: 0;
    border: none;
  }

  :global(.globe-canvas) {
    width: 100%;
    height: 100%;
  }

  :global(.globe-search) {
    position: absolute;
    top: 1rem;
    left: 1rem;
    right: 1rem;
    z-index: 1;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  :global(.globe-search input) {
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.6rem 0.75rem;
    font-size: 0.875rem;
    width: 16rem;
    max-width: 60vw;
  }

  :global(.globe-search button) {
    background: var(--color-accent);
    color: #101418;
    font-weight: 600;
    font-size: 0.875rem;
    border: none;
    border-radius: 0.5rem;
    padding: 0.6rem 1.1rem;
    min-height: 2.5rem;
    cursor: pointer;
  }

  :global(.globe-error) {
    position: absolute;
    top: 3.5rem;
    left: 1rem;
    z-index: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    max-width: 60vw;
  }

  :global(.maplibregl-popup-content) {
    background: var(--color-bg-alt);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    font-family: var(--font-sans);
    padding: 0.75rem 0.9rem;
  }

  :global(.maplibregl-popup-tip) {
    border-top-color: var(--color-bg-alt) !important;
    border-bottom-color: var(--color-bg-alt) !important;
  }

  :global(.maplibregl-popup-close-button) {
    color: var(--color-text-muted);
    font-size: 1rem;
    padding: 0.5rem;
    width: 2rem;
    height: 2rem;
  }

  :global(.maplibregl-popup) {
    max-width: min(16rem, 80vw) !important;
  }

  :global(.place-popup) {
    min-width: 9rem;
    overflow-wrap: break-word;
  }

  :global(.place-popup-location) {
    font-size: 0.8125rem;
    font-weight: 600;
    margin-bottom: 0.3rem;
    padding-bottom: 0.3rem;
    border-bottom: 1px solid var(--color-border);
  }

  :global(.place-popup-time) {
    font-size: 1.375rem;
    font-weight: 700;
    color: var(--color-accent);
    line-height: 1.15;
    font-variant-numeric: tabular-nums;
  }

  :global(.place-popup-date) {
    font-size: 0.75rem;
    color: var(--color-text-muted);
    margin-top: 0.15rem;
  }

  :global(.place-popup-tz) {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    opacity: 0.8;
    margin-top: 0.35rem;
  }

  :global(.layers-panel) {
    position: absolute;
    top: 1rem;
    /* Sits just left of the top-right control stack (nav/fullscreen/layers
       buttons) rather than under it. */
    right: 3.5rem;
    z-index: 1;
    width: min(14rem, calc(100vw - 6rem));
    max-height: calc(100% - 2rem);
    overflow-y: auto;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.75rem;
    padding: 0.75rem;
  }

  :global(.layers-panel-header) {
    display: flex;
    align-items: center;
    justify-content: space-between;
    font-size: 0.875rem;
    font-weight: 600;
    margin-bottom: 0.5rem;
  }

  :global(.layers-panel-header button) {
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 1.125rem;
    line-height: 1;
    cursor: pointer;
    padding: 0.4rem;
    margin: -0.4rem;
  }

  :global(.layers-item) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.8125rem;
    color: var(--color-text);
    cursor: pointer;
    padding-block: 0.2rem;
  }

  :global(.layers-section-label) {
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-text-muted);
    margin: 0.75rem 0 0.25rem;
  }

  :global(.layers-section-label:first-of-type) {
    margin-top: 0;
  }
</style>

<Layout title="Map — 7 Beacons" description="Interactive 3D globe with coordinate search.">
  <Header siteName="7 Beacons" />
  <section class="container">
    <h1>Map</h1>
    <p class="intro">
      A 3D globe you can drag, zoom, and tilt. Enter coordinates below to fly
      straight to a location, click anywhere for that spot's local time and
      place (city, state/province, country), use the fullscreen button
      (top-right) to maximize it, or open the layers panel below it to
      switch base styles or toggle the day/night terminator.
    </p>
    <GlobeMap client:load />
  </section>
  <Footer />
</Layout>
