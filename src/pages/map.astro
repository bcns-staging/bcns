---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import GlobeMap from "../components/map/GlobeMap.tsx";
---

<style>
  section {
    padding-block: 2rem 3rem;
  }

  h1 {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    margin: 0 0 0.5rem;
  }

  .intro {
    color: var(--color-text-muted);
    max-width: 60ch;
    margin: 0 0 1.5rem;
  }

  :global(.globe-wrap) {
    position: relative;
    width: 100%;
    height: min(70vh, 40rem);
    border-radius: 0.75rem;
    overflow: hidden;
    border: 1px solid var(--color-border);
  }

  :global(.globe-canvas) {
    width: 100%;
    height: 100%;
  }

  :global(.globe-search) {
    position: absolute;
    top: 1rem;
    left: 1rem;
    z-index: 1;
    display: flex;
    gap: 0.5rem;
  }

  :global(.globe-search input) {
    background: var(--color-bg);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.5rem 0.75rem;
    font-size: 0.875rem;
    width: 16rem;
    max-width: 60vw;
  }

  :global(.globe-search button) {
    background: var(--color-accent);
    color: #101418;
    font-weight: 600;
    font-size: 0.875rem;
    border: none;
    border-radius: 0.5rem;
    padding: 0.5rem 1rem;
    cursor: pointer;
  }

  :global(.globe-error) {
    position: absolute;
    top: 3.5rem;
    left: 1rem;
    z-index: 1;
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.75rem;
    font-size: 0.75rem;
    color: var(--color-text-muted);
    max-width: 60vw;
  }

  :global(.beacon-marker) {
    width: 1rem;
    height: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
  }

  :global(.beacon-dot) {
    width: 0.6rem;
    height: 0.6rem;
    border-radius: 999px;
    background: var(--color-accent);
    box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 60%, transparent);
    animation: beacon-pulse 2s ease-out infinite;
  }

  @keyframes beacon-pulse {
    0% {
      box-shadow: 0 0 0 0 color-mix(in srgb, var(--color-accent) 55%, transparent);
    }
    100% {
      box-shadow: 0 0 0 0.9rem transparent;
    }
  }

  :global(.maplibregl-popup-content) {
    background: var(--color-bg-alt);
    color: var(--color-text);
    border: 1px solid var(--color-border);
    font-family: var(--font-sans);
    font-size: 0.8125rem;
    padding: 0.6rem 0.8rem;
  }

  :global(.maplibregl-popup-tip) {
    border-top-color: var(--color-bg-alt) !important;
    border-bottom-color: var(--color-bg-alt) !important;
  }

  :global(.maplibregl-popup-close-button) {
    color: var(--color-text-muted);
  }

  :global(.plane-marker) {
    width: 1.125rem;
    height: 1.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #8fd3ff;
    filter: drop-shadow(0 0 3px rgba(143, 211, 255, 0.7));
  }

  :global(.flight-controls) {
    position: absolute;
    bottom: 1rem;
    left: 1rem;
    z-index: 1;
    display: flex;
    gap: 0.4rem;
  }

  :global(.flight-btn) {
    background: var(--color-bg);
    color: var(--color-text-muted);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.4rem 0.7rem;
    font-size: 0.75rem;
    font-weight: 600;
    cursor: pointer;
  }

  :global(.flight-btn.active) {
    background: var(--color-accent);
    color: #101418;
    border-color: var(--color-accent);
  }

  :global(.live-controls) {
    position: absolute;
    bottom: 1rem;
    right: 1rem;
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  :global(.live-status) {
    font-size: 0.7rem;
    color: var(--color-text-muted);
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: 0.5rem;
    padding: 0.3rem 0.6rem;
  }
</style>

<Layout title="Map — 7 Beacons" description="Interactive 3D globe with coordinate search.">
  <Header siteName="7 Beacons" />
  <section class="container">
    <h1>Map</h1>
    <p class="intro">
      A 3D globe you can drag, zoom, and tilt. Enter coordinates below to fly
      straight to a location, click a glowing beacon for details, or watch
      the tracked flight from New York to San Francisco (bottom-left controls
      pause it or speed it up). The bottom-right toggle shows real live air
      traffic near New York, pulled from a public ADS-B feed.
    </p>
    <GlobeMap client:load />
  </section>
  <Footer />
</Layout>
